# ============================================================
# NORTHPAY BACKEND - Variables de Entorno
# Copiar este archivo como .env y completar con tus valores
# ============================================================

# MONGODB ATLAS
# URI de conexion de MongoDB Atlas (o local: mongodb://localhost:27017/northpay_db)
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_DATABASE=northpay_db

# CLOUDINARY (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# MAIL (opcional - para notificaciones)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_app_password

# SERVIDOR
SERVER_PORT=8080

# JWT (minimo 32 caracteres para HS256 - genera uno aleatorio en produccion)
JWT_SECRET=change_me_min_32_chars_random_secret
JWT_EXPIRATION=86400000

# FRONTEND
FRONTEND_URL=http://localhost:5173

# STRIPE
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OPENSIGN
OPENSIGN_API_KEY=test.xxx
OPENSIGN_BASE_URL=https://api.opensignlabs.com/api
